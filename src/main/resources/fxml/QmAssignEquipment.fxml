<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.qm.QmAssignEquipmentController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button text="Quartermaster" styleClass="nav-tab active" onAction="#onQuartermaster"/>
                    <Button text="Admin" styleClass="nav-tab" onAction="#onAdmin"/>
                    <Button text="Narcotics" styleClass="nav-tab"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard"          styleClass="nav-tab" onAction="#onQuartermaster"/>
                <Button text="Assign Equipment"   styleClass="nav-tab active" onAction="#onAssignEquipment"/>
                <Button text="Equipment"          styleClass="nav-tab" onAction="#onEquipment"/>
                <Button text="Weapons"            styleClass="nav-tab" onAction="#onWeapons"/>
                <Button text="Uniforms"           styleClass="nav-tab" onAction="#onUniforms"/>
                <Button text="Ammunition"         styleClass="nav-tab" onAction="#onAmmunition"/>
                <Button text="Inventory Levels"   styleClass="nav-tab" onAction="#onInventoryLevels"/>
                <Button text="Inventory Audit"    styleClass="nav-tab" onAction="#onInventoryAudit"/>
                <Button text="Loadout Reports"    styleClass="nav-tab" onAction="#onOfficerLoadouts"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-background-color: #1a2235;">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
            <Label text="Quartermaster  /  Assign Equipment" styleClass="breadcrumb-text"/>
            <Label text="Assign Equipment" styleClass="page-title"/>
            <Separator/>

            <!-- Filter bar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="tfSearch" promptText="Search name / serial…" prefWidth="220"/>
                <ComboBox fx:id="cbCategoryFilter" prefWidth="130"/>
                <ComboBox fx:id="cbStatusFilter"   prefWidth="130"/>
                <Button text="+ Add Equipment" styleClass="btn-primary" onAction="#onAddEquipment"/>
            </HBox>

            <!-- Equipment inventory -->
            <Label text="Equipment Inventory" styleClass="section-title"/>
            <TableView fx:id="equipTable" prefHeight="260" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colName"       text="Name"       prefWidth="160"/>
                    <TableColumn fx:id="colCategory"   text="Category"   prefWidth="100"/>
                    <TableColumn fx:id="colMake"       text="Make"       prefWidth="100"/>
                    <TableColumn fx:id="colModel"      text="Model"      prefWidth="100"/>
                    <TableColumn fx:id="colSerial"     text="Serial #"   prefWidth="120"/>
                    <TableColumn fx:id="colStatus"     text="Status"     prefWidth="100"/>
                    <TableColumn fx:id="colEquipAction" text=""          prefWidth="200"/>
                </columns>
                <placeholder><Label text="No equipment found"/></placeholder>
            </TableView>

            <!-- Active assignments -->
            <Label text="Active Assignments" styleClass="section-title"/>
            <TableView fx:id="assignTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colAOfficer"  text="Officer"       prefWidth="150"/>
                    <TableColumn fx:id="colAItem"     text="Equipment"     prefWidth="160"/>
                    <TableColumn fx:id="colACategory" text="Category"      prefWidth="100"/>
                    <TableColumn fx:id="colASerial"   text="Serial #"      prefWidth="120"/>
                    <TableColumn fx:id="colADate"     text="Assigned Date" prefWidth="140"/>
                    <TableColumn fx:id="colAAction"   text=""              prefWidth="90"/>
                </columns>
                <placeholder><Label text="No active assignments"/></placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
