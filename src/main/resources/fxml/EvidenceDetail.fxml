<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.inventory.EvidenceDetailController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="Evidence Harbor" styleClass="brand-title"/>
            <Label text=" — Evidence Detail" styleClass="subtitle"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="14">
                <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

                <!-- Header: Barcode + status + actions -->
                <VBox styleClass="card" spacing="10">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <VBox spacing="4">
                            <Label text="BARCODE" styleClass="label-key"/>
                            <Label fx:id="labelBarcode" styleClass="page-title"
                                   style="-fx-font-family: 'Consolas','Courier New',monospace; -fx-font-size: 26; -fx-font-weight: bold;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="labelStatusBadge" styleClass="subtitle"
                               style="-fx-font-weight: bold; -fx-padding: 6 14 6 14; -fx-background-radius: 6; -fx-font-size: 14;"/>
                        <Button text="🖨 Print Evidence Sheet" styleClass="btn-primary" onAction="#onPrint"/>
                        <Button text="🏷 Print Barcode Label" styleClass="btn-primary" onAction="#onPrintLabel"/>
                        <Button text="Add Transfer / CoC Entry" styleClass="btn-secondary" onAction="#onAddTransfer"/>
                        <Button text="Close" styleClass="btn-secondary" onAction="#onClose"/>
                    </HBox>
                    <Canvas fx:id="barcodeCanvas" height="60" width="520"/>
                </VBox>

                <!-- Overview -->
                <VBox styleClass="card" spacing="8">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="Overview" styleClass="section-title"/>
                    <GridPane hgap="16" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Case #:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="infoCase" styleClass="label-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Evidence Type:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="infoType" styleClass="label-value" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Collection Date:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="infoDate" styleClass="label-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Status:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <Label fx:id="infoStatus" styleClass="label-value" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="Storage Location:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="infoLocation" styleClass="label-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="Description:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <Label fx:id="infoDescription" styleClass="label-value" wrapText="true"
                               GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>

                <!-- Collection Location / Collector -->
                <VBox styleClass="card" spacing="8">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="Collection" styleClass="section-title"/>
                    <GridPane hgap="16" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Collected By:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="infoCollectedBy" styleClass="label-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Collected From:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <Label fx:id="infoCollectedFrom" styleClass="label-value" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Specific Location:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="infoSpecificLocation" styleClass="label-value" wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Address:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <Label fx:id="infoAddress" styleClass="label-value" wrapText="true"
                               GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="City:" styleClass="label-key" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="infoCity" styleClass="label-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="State / ZIP:" styleClass="label-key" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <Label fx:id="infoStateZip" styleClass="label-value" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>

                <!-- Type-specific details (populated dynamically) -->
                <VBox fx:id="typeDetailsCard" styleClass="card" spacing="8" managed="false" visible="false">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label fx:id="typeDetailsTitle" text="Item Details" styleClass="section-title"/>
                    <GridPane fx:id="typeDetailsGrid" hgap="16" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="170"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints prefWidth="170"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                    </GridPane>
                </VBox>

                <!-- Chain of Custody log -->
                <VBox styleClass="card" spacing="8" VBox.vgrow="ALWAYS">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Chain of Custody Log" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="cocCountLabel" styleClass="subtitle"/>
                    </HBox>
                    <TableView fx:id="cocTable" styleClass="data-table" VBox.vgrow="ALWAYS" prefHeight="240">
                        <columns>
                            <TableColumn fx:id="cocColTimestamp" text="DATE / TIME" prefWidth="160"/>
                            <TableColumn fx:id="cocColAction" text="ACTION" prefWidth="160"/>
                            <TableColumn fx:id="cocColPerformedBy" text="PERFORMED BY" prefWidth="150"/>
                            <TableColumn fx:id="cocColFrom" text="FROM" prefWidth="130"/>
                            <TableColumn fx:id="cocColTo" text="TO LOCATION" prefWidth="130"/>
                            <TableColumn fx:id="cocColToPerson" text="TO PERSON" prefWidth="120"/>
                            <TableColumn fx:id="cocColNotes" text="NOTES" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
