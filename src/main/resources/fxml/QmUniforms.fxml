<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.qm.QmUniformsController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button text="Quartermaster" styleClass="nav-tab active" onAction="#onQuartermaster"/>
                    <Button text="Admin" styleClass="nav-tab" onAction="#onAdmin"/>
                    <Button text="Narcotics" styleClass="nav-tab"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard"          styleClass="nav-tab" onAction="#onQuartermaster"/>
                <Button text="Assign Equipment"   styleClass="nav-tab" onAction="#onAssignEquipment"/>
                <Button text="Equipment"          styleClass="nav-tab" onAction="#onEquipment"/>
                <Button text="Weapons"            styleClass="nav-tab" onAction="#onWeapons"/>
                <Button text="Uniforms"           styleClass="nav-tab active" onAction="#onUniforms"/>
                <Button text="Ammunition"         styleClass="nav-tab" onAction="#onAmmunition"/>
                <Button text="Inventory Levels"   styleClass="nav-tab" onAction="#onInventoryLevels"/>
                <Button text="Inventory Audit"    styleClass="nav-tab" onAction="#onInventoryAudit"/>
                <Button text="Loadout Reports"    styleClass="nav-tab" onAction="#onOfficerLoadouts"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-background-color: #1a2235;">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
            <Label text="Quartermaster  /  Uniforms" styleClass="breadcrumb-text"/>
            <Label text="Uniforms Inventory" styleClass="page-title"/>
            <Separator/>

            <!-- Filter bar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="tfSearch" promptText="Search uniforms…" prefWidth="220"/>
                <ComboBox fx:id="cbTypeFilter" prefWidth="130"/>
                <ComboBox fx:id="cbSizeFilter" prefWidth="130"/>
                <Button text="+ Add Uniform" styleClass="btn-primary" onAction="#onAddUniform"/>
            </HBox>

            <!-- Uniforms table -->
            <Label text="Uniforms List" styleClass="section-title"/>
            <TableView fx:id="uniformsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colDescription" text="Description"  prefWidth="200"/>
                    <TableColumn fx:id="colType"        text="Type"         prefWidth="120"/>
                    <TableColumn fx:id="colSize"        text="Size"         prefWidth="80"/>
                    <TableColumn fx:id="colBrand"       text="Brand"        prefWidth="100"/>
                    <TableColumn fx:id="colCondition"   text="Condition"    prefWidth="120"/>
                    <TableColumn fx:id="colQuantity"    text="Quantity"     prefWidth="100"/>
                    <TableColumn fx:id="colStatus"      text="Status"       prefWidth="100"/>
                    <TableColumn fx:id="colAction"      text=""             prefWidth="80"/>
                </columns>
                <placeholder><Label text="No uniforms found"/></placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
