<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.admin.EvidenceAuditController"
            styleClass="root-pane">
    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button fx:id="navAdminTab" text="Admin" styleClass="nav-tab active" onAction="#onAdmin"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard" styleClass="nav-tab" onAction="#onAdmin"/>
                <Button text="User Management" styleClass="nav-tab" onAction="#onUserManagement"/>
                <Button text="Lookup Admin" styleClass="nav-tab" onAction="#onLookupAdministration"/>
                <Button text="Evidence Audit" styleClass="nav-tab active" onAction="#onEvidenceAudit"/>
                <Button fx:id="navAuditTrailBtn" text="Audit Trail" styleClass="nav-tab" onAction="#onAuditTrail"/>
                <Button text="Bank Ledger" styleClass="nav-tab" onAction="#onBankAccountLedger"/>
                <Button fx:id="navSettingsBtn" text="Settings" styleClass="nav-tab" onAction="#onSettings"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
            <HBox spacing="12">
                <Button text="◀  Previous Page" styleClass="btn-secondary" onAction="#onBack"/>
                <Button text="⌂  Dashboard" styleClass="btn-secondary" onAction="#onDashboard"/>
            </HBox>
            <Label text="Admin &gt; Evidence Storage Audit" styleClass="breadcrumb-text"/>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Evidence Storage Audit" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🖨 Print" styleClass="btn-secondary" onAction="#onPrint"/>
                <Button text="+ New Audit" styleClass="btn-primary" onAction="#onNewAudit"/>
            </HBox>
            <Separator/>

            <!-- In-progress audits -->
            <Label text="In Progress" styleClass="section-title"/>
            <VBox styleClass="card" spacing="0">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <TableView fx:id="inProgressTable" styleClass="data-table" prefHeight="180">
                    <columns>
                        <TableColumn fx:id="colIPDate"   text="STARTED"   prefWidth="160"/>
                        <TableColumn fx:id="colIPType"   text="TYPE"       prefWidth="130"/>
                        <TableColumn fx:id="colIPScope"  text="SCOPE"      prefWidth="200"/>
                        <TableColumn fx:id="colIPBy"     text="CREATED BY" prefWidth="170"/>
                        <TableColumn fx:id="colIPStatus" text="STATUS"     prefWidth="120"/>
                        <TableColumn fx:id="colIPAction" text=""           prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="No audits in progress." styleClass="empty-placeholder"/></placeholder>
                </TableView>
            </VBox>

            <!-- Completed audits -->
            <Label text="Completed" styleClass="section-title"/>
            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <TableView fx:id="completedTable" styleClass="data-table" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colCDate"   text="COMPLETED"  prefWidth="160"/>
                        <TableColumn fx:id="colCType"   text="TYPE"        prefWidth="130"/>
                        <TableColumn fx:id="colCScope"  text="SCOPE"       prefWidth="200"/>
                        <TableColumn fx:id="colCBy"     text="CREATED BY"  prefWidth="170"/>
                        <TableColumn fx:id="colCStatus" text="STATUS"      prefWidth="120"/>
                        <TableColumn fx:id="colCAction" text=""            prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="No completed audits." styleClass="empty-placeholder"/></placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
