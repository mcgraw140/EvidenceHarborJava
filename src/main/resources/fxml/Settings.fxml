<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.settings.SettingsController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button fx:id="navAdminTab" text="Admin" styleClass="nav-tab active" onAction="#onAdmin"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard" styleClass="nav-tab" onAction="#onAdmin"/>
                <Button fx:id="navSettingsBtn" text="Settings" styleClass="nav-tab active" onAction="#onSettings"/>
                <Button fx:id="navAuditTrailBtn" text="Audit Trail" styleClass="nav-tab" onAction="#onAuditTrail"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <Label text="System Settings" styleClass="page-title"/>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <!-- ── AGENCY INFO TAB ── -->
                <Tab text="Agency Info">
                    <ScrollPane fitToWidth="true" styleClass="card">
                        <VBox spacing="18">
                            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

                            <Label text="Agency Information" styleClass="section-header"/>

                            <GridPane hgap="16" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="160" prefWidth="180" hgrow="NEVER"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Agency Name"   GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="agencyNameField" promptText="e.g. Riverside Police Department"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Street Address" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="agencyAddressField" promptText="e.g. 123 Main Street"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="City"          GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="agencyCityField" promptText="e.g. Riverside"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="State"         GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="agencyStateField" promptText="e.g. CA"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="ZIP"           GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="agencyZipField" promptText="e.g. 92501"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <Separator/>

                            <Label text="Number Formats" styleClass="section-header"/>
                            <Label text="Use regex patterns to validate Case and Evidence numbers. Leave blank to skip validation."
                                   styleClass="subtitle" wrapText="true"/>

                            <GridPane hgap="16" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="160" prefWidth="180" hgrow="NEVER"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints prefWidth="200" hgrow="NEVER"/>
                                </columnConstraints>

                                <Label text="Case # Pattern"   GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="casePatternField" promptText="e.g. ^d{2}-d{5}$"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                <Label fx:id="casePatternStatus" text="" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="subtitle"/>

                                <Label text="Case # Example"   GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="caseExampleField" promptText="e.g. 26-00001"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                <Label fx:id="caseValidationLabel" text="" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="subtitle"/>

                                <Label text="Evidence # Pattern" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="evidencePatternField" promptText="e.g. ^EV-d{4}-d{5}$"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                <Label fx:id="evidencePatternStatus" text="" GridPane.rowIndex="2" GridPane.columnIndex="2" styleClass="subtitle"/>

                                <Label text="Evidence # Example" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="evidenceExampleField" promptText="e.g. EV-2026-00001"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                <Label fx:id="evidenceValidationLabel" text="" GridPane.rowIndex="3" GridPane.columnIndex="2" styleClass="subtitle"/>
                            </GridPane>

                            <Separator/>

                            <Label text="Barcode Settings (Code 128)" styleClass="section-header"/>
                            <Label text="Code 128 barcodes are auto-generated using: PREFIX + YYYYMMDD + sequential number."
                                   styleClass="subtitle" wrapText="true"/>

                            <GridPane hgap="16" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="160" prefWidth="180" hgrow="NEVER"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                    <ColumnConstraints prefWidth="200" hgrow="NEVER"/>
                                </columnConstraints>

                                <Label text="Barcode Prefix" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="barcodePrefixField" promptText="e.g. EV or RPD"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                <Label fx:id="barcodePreviewLabel" text="" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="subtitle"/>
                            </GridPane>

                            <HBox spacing="12" alignment="CENTER_RIGHT">
                                <Button text="Save Agency Settings" styleClass="btn-primary" onAction="#onSaveAgency"/>
                            </HBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- ── TAILSCALE TAB ── -->
                <Tab text="Tailscale VPN">
                    <ScrollPane fitToWidth="true" styleClass="card">
                        <VBox spacing="18">
                            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

                            <Label text="Tailscale VPN" styleClass="section-header"/>
                            <Label text="Tailscale creates a secure private network between all agency machines. Once connected, use your Tailscale IP as the database host to reach a remote MariaDB server."
                                   styleClass="subtitle" wrapText="true"/>

                            <!-- Status row -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="tsStatusDot" text="●" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#f59e0b;"/>
                                <VBox spacing="2">
                                    <Label fx:id="tsStatusLabel" text="Checking Tailscale..." styleClass="field-label"/>
                                    <Label fx:id="tsIpLabel" text="" style="-fx-font-size:11px; -fx-text-fill:#64748b;"/>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <!-- Install section (shown when not installed) -->
                            <VBox fx:id="tsInstallBox" spacing="10">
                                <Label text="Tailscale Not Installed" styleClass="section-header"/>
                                <Label text="The bundled installer (tailscale-setup-1.96.3.exe) will be run silently."
                                       styleClass="subtitle" wrapText="true"/>
                                <HBox spacing="12">
                                    <Button text="Install Tailscale" styleClass="btn-primary" onAction="#onInstallTailscale"/>
                                </HBox>
                            </VBox>

                            <!-- Connect section (shown when installed) -->
                            <VBox fx:id="tsConnectBox" spacing="14">
                                <Label text="Authentication" styleClass="section-header"/>
                                <Label text="Paste an Auth Key from the Tailscale admin console to join your agency network automatically. Leave blank to connect using the browser login flow."
                                       styleClass="subtitle" wrapText="true"/>

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="160" prefWidth="180" hgrow="NEVER"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <Label text="Auth Key (optional)" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                                    <PasswordField fx:id="tsAuthKeyField" promptText="tskey-auth-..."
                                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                </GridPane>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Button text="Connect / Up" styleClass="btn-primary" onAction="#onTailscaleConnect"/>
                                    <Button text="Disconnect / Down" styleClass="btn-secondary" onAction="#onTailscaleDisconnect"/>
                                    <Button text="Refresh Status" styleClass="btn-secondary" onAction="#onTailscaleRefresh"/>
                                </HBox>

                                <Separator/>

                                <Label text="Use Tailscale IP as Database Host" styleClass="section-header"/>
                                <Label text="After connecting, click below to copy your Tailscale IP into the Database Connection settings."
                                       styleClass="subtitle" wrapText="true"/>
                                <HBox spacing="12">
                                    <Button text="Use My Tailscale IP as DB Host" styleClass="btn-secondary" onAction="#onUseTailscaleIpAsDbHost"/>
                                </HBox>
                            </VBox>

                            <Separator/>

                            <Label text="Tailscale Output" styleClass="section-header"/>
                            <TextArea fx:id="tsLogArea" editable="false" wrapText="true" prefRowCount="10"
                                      style="-fx-control-inner-background:#101827; -fx-text-fill:#dbeafe; -fx-border-color:#2d4059;"/>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- ── DATABASE CONNECTION TAB ── -->
                <Tab text="Database Connection">
                    <ScrollPane fitToWidth="true" styleClass="card">
                        <VBox spacing="18">
                            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

                            <Label text="MariaDB Connection" styleClass="section-header"/>

                            <!-- Live status row -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="dbStatusDot" text="●" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
                                <Label fx:id="dbStatusLabel" text="Checking..." styleClass="field-label"/>
                            </HBox>

                            <Separator/>

                            <Label text="Connection Settings" styleClass="section-header"/>

                            <GridPane hgap="16" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="160" prefWidth="180" hgrow="NEVER"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Server Host"      GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="dbHostField" promptText="e.g. 127.0.0.1"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Port"             GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="dbPortField" promptText="3306"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Database Name"    GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="dbNameField" promptText="e.g. evidence_harbor"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="MariaDB User"     GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
                                <TextField fx:id="dbUserField" promptText="e.g. root"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Password"         GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label"/>
                                <PasswordField fx:id="dbPasswordField"
                                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <Separator/>

                            <!-- Local data directory (host PC only) -->
                            <Label text="Local Data Directory" styleClass="section-header"/>
                            <Label text="If MariaDB is running on THIS PC, set the data folder below so you can quickly locate your database files."
                                   wrapText="true" styleClass="subtitle"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="dbDataDirField"
                                           promptText="e.g. C:\Program Files\MariaDB 12.2\data\evidence_harbor"
                                           HBox.hgrow="ALWAYS"/>
                                <Button text="Browse…" styleClass="btn-secondary" onAction="#onBrowseDataDir"/>
                                <Button text="Open in Explorer" styleClass="btn-secondary" onAction="#onOpenDataDir"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_RIGHT">
                                <Button text="Test Connection" styleClass="btn-secondary" onAction="#onTestConnection"/>
                                <Button text="Save &amp; Reconnect" styleClass="btn-primary" onAction="#onSaveReconnect"/>
                            </HBox>

                            <Label fx:id="dbTestResultLabel" text="" wrapText="true" styleClass="subtitle"/>

                            <Separator/>

                            <Label text="Connection Log" styleClass="section-header"/>
                            <TextArea fx:id="dbLogArea" editable="false" wrapText="true" prefRowCount="8"
                                      style="-fx-control-inner-background:#101827; -fx-text-fill:#dbeafe; -fx-border-color:#2d4059;"/>

                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </VBox>
    </center>

    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
