<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.people.PeopleController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab active" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button fx:id="navAdminTab" text="Admin" styleClass="nav-tab" onAction="#onAdmin"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard" styleClass="nav-tab" onAction="#onEvidenceDashboard"/>
                <Button text="Cases" styleClass="nav-tab" onAction="#onCases"/>
                <Button fx:id="navInventoryBtn" text="Inventory" styleClass="nav-tab" onAction="#onInventory"/>
                <Button fx:id="navDropboxBtn" text="Dropbox Check-in" styleClass="nav-tab" onAction="#onDropbox"/>
                <Button fx:id="navReportsBtn" text="Reports" styleClass="nav-tab" onAction="#onReports"/>
                <Button text="People" styleClass="nav-tab active" onAction="#onPeople"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <HBox spacing="12">
                <Button text="◀  Previous Page" styleClass="btn-secondary" onAction="#onBack"/>
                <Button text="⌂  Dashboard" styleClass="btn-secondary" onAction="#onDashboard"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="People Directory" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search people..." styleClass="search-field" prefWidth="260"/>
                <Button fx:id="btnEdit"  text="Edit Name"   styleClass="btn-secondary" onAction="#onEditPerson"  disable="true"/>
                <Button fx:id="btnMerge" text="Combine..."  styleClass="btn-secondary" onAction="#onMergePeople" disable="true"/>
                <Button text="🖨 Print" styleClass="btn-secondary" onAction="#onPrint"/>
            </HBox>

            <Label text="Double-click a person to view their cases. Admins and Evidence Techs can rename or combine duplicates."
                   styleClass="subtitle" wrapText="true"/>

            <VBox styleClass="card" spacing="0">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <TableView fx:id="peopleTable" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName"    text="NAME"         prefWidth="200"/>
                        <TableColumn fx:id="colDob"     text="DOB"          prefWidth="100"/>
                        <TableColumn fx:id="colSsn"     text="SSN"          prefWidth="110"/>
                        <TableColumn fx:id="colAddress" text="ADDRESS"      prefWidth="260"/>
                        <TableColumn fx:id="colContact" text="CONTACT"      prefWidth="140"/>
                        <TableColumn fx:id="colCases"   text="# CASES"      prefWidth="80"/>
                    </columns>
                    <placeholder><Label text="No people recorded." styleClass="placeholder-label"/></placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
