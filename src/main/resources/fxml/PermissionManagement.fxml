<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.admin.PermissionManagementController"
            styleClass="root-pane">
    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button fx:id="navAdminTab" text="Admin" styleClass="nav-tab active" onAction="#onAdmin"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard" styleClass="nav-tab" onAction="#onAdmin"/>
                <Button fx:id="navSettingsBtn" text="Settings" styleClass="nav-tab" onAction="#onSettings"/>
                <Button fx:id="navAuditTrailBtn" text="Audit Trail" styleClass="nav-tab" onAction="#onAuditTrail"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
            <Label text="Admin &gt; User Management &gt; Permissions" styleClass="breadcrumb-text"/>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="pageTitle" text="Configure Permissions" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Officer Preset"       styleClass="btn-secondary" onAction="#onOfficerPreset"/>
                <Button text="Evidence Tech Preset" styleClass="btn-secondary" onAction="#onEvidenceTechPreset"/>
                <Button text="Admin Preset"         styleClass="btn-secondary" onAction="#onAdminPreset"/>
                <Button text="Select All"           styleClass="btn-secondary" onAction="#onSelectAll"/>
                <Button text="Clear All"            styleClass="btn-secondary" onAction="#onClearAll"/>
                <Button text="Save"                 styleClass="btn-primary"   onAction="#onSave"/>
            </HBox>
            <Separator/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="permissionsContainer" spacing="12">
                    <padding><Insets top="8" right="0" bottom="8" left="0"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
