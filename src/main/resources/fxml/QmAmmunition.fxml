<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.qm.QmAmmunitionController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button text="Quartermaster" styleClass="nav-tab active" onAction="#onQuartermaster"/>
                    <Button text="Narcotics" styleClass="nav-tab"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Dashboard"          styleClass="nav-tab" onAction="#onQuartermaster"/>
                <Button text="Assign Equipment"   styleClass="nav-tab" onAction="#onAssignEquipment"/>
                <Button text="Equipment"          styleClass="nav-tab" onAction="#onEquipment"/>
                <Button text="Weapons"            styleClass="nav-tab" onAction="#onWeapons"/>
                <Button text="Uniforms"           styleClass="nav-tab" onAction="#onUniforms"/>
                <Button text="Ammunition"         styleClass="nav-tab active" onAction="#onAmmunition"/>
                <Button text="Inventory Levels"   styleClass="nav-tab" onAction="#onInventoryLevels"/>
                <Button text="Inventory Audit"    styleClass="nav-tab" onAction="#onInventoryAudit"/>
                <Button text="Loadout Reports"    styleClass="nav-tab" onAction="#onOfficerLoadouts"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
            <Label text="Quartermaster  /  Ammunition" styleClass="breadcrumb-text"/>
            <Label text="Ammunition Stock" styleClass="page-title"/>
            <Separator/>
            <HBox alignment="CENTER_LEFT">
                <Button text="+ Add Ammunition" styleClass="btn-primary" onAction="#onAdd"/>
            </HBox>
            <TableView fx:id="ammoTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCaliber"  text="Caliber"      prefWidth="140"/>
                    <TableColumn fx:id="colQuantity" text="Quantity"      prefWidth="100"/>
                    <TableColumn fx:id="colLocation" text="Location"      prefWidth="160"/>
                    <TableColumn fx:id="colUpdated"  text="Last Updated"  prefWidth="160"/>
                    <TableColumn fx:id="colNotes"    text="Notes"         prefWidth="200"/>
                    <TableColumn fx:id="colAction"   text=""              prefWidth="140"/>
                </columns>
                <placeholder><Label text="No ammunition records"/></placeholder>
            </TableView>
        </VBox>
    </center>

</BorderPane>
