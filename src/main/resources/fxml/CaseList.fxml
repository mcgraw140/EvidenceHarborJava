<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.evidenceharbor.ui.cases.CaseListController"
            styleClass="root-pane">

    <top>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="18">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
                <Label text="Evidence Harbor" styleClass="brand-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="main-module-tabs" spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Evidence" styleClass="nav-tab active" onAction="#onCases"/>
                    <Button text="Impound" styleClass="nav-tab" onAction="#onImpound"/>
                    <Button fx:id="navAdminTab" text="Admin" styleClass="nav-tab" onAction="#onAdmin"/>
                </HBox>
            </HBox>
            <HBox styleClass="module-nav" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
                <Button text="Cases" styleClass="nav-tab active" onAction="#onCases"/>
                <Button fx:id="navInventoryBtn" text="Inventory" styleClass="nav-tab" onAction="#onInventory"/>
                <Button fx:id="navDropboxBtn" text="Dropbox Check-in" styleClass="nav-tab" onAction="#onDropbox"/>
                <Button fx:id="navReportsBtn" text="Reports" styleClass="nav-tab" onAction="#onReports"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <HBox spacing="12">
                <Button text="◀  Previous Page" styleClass="btn-secondary" onAction="#onCases"/>
                <Button text="⌂  Dashboard" styleClass="btn-secondary" onAction="#onCases"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Case Management" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search by Case #, Person, Officer..."
                           styleClass="search-field" prefWidth="320"/>
                <Button text="+ New Case" styleClass="btn-primary" onAction="#onNewCase"/>
            </HBox>

            <VBox styleClass="card" spacing="0">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <TableView fx:id="caseTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colCaseNumber" text="CASE #"            prefWidth="160"/>
                        <TableColumn fx:id="colDate"        text="DATE"             prefWidth="120"/>
                        <TableColumn fx:id="colPeople"      text="ASSOCIATED PEOPLE" prefWidth="420"/>
                        <TableColumn fx:id="colOfficer"     text="SEIZED BY"        prefWidth="180"/>
                    </columns>
                    <placeholder><Label text="No cases found." styleClass="placeholder-label"/></placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
    <bottom><fx:include source="DbStatusBar.fxml"/></bottom>
</BorderPane>
